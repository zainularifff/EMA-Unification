/* TASKLIST UI FINAL CLEAN
   CSS only. No runtime observer.
   Scoped by TaskList search placeholder.
*/

body:has(input[placeholder*="Search job" i]) {
  --tl-border: #dbe7f6;
  --tl-text: #0f2746;
  --tl-muted: #64748b;
  --tl-blue: #2563eb;
}

/* Fallback hide stray Dark Mode button if JSX button remains */
body:has(input[placeholder*="Search job" i]) #root > button:first-child,
body:has(input[placeholder*="Search job" i]) main > button:first-child,
body:has(input[placeholder*="Search job" i]) [class*="task" i] > button:first-child {
  display: none !important;
}

/* Page spacing */
body:has(input[placeholder*="Search job" i]) main,
body:has(input[placeholder*="Search job" i]) [class*="content" i],
body:has(input[placeholder*="Search job" i]) [class*="page" i] {
  box-sizing: border-box !important;
}

/* Top title card */
body:has(input[placeholder*="Search job" i]) :is(section, article, div):has(h1):has(input[placeholder*="Search job" i]) {
  box-sizing: border-box !important;
}

/* Search + filter card */
body:has(input[placeholder*="Search job" i]) :is(section, article, div):has(input[placeholder*="Search job" i]) {
  box-sizing: border-box !important;
}

/* Compact all controls inside TaskList */
body:has(input[placeholder*="Search job" i]) input,
body:has(input[placeholder*="Search job" i]) select {
  height: 34px !important;
  min-height: 34px !important;

  border-radius: 11px !important;

  font-size: 11px !important;
  font-weight: 750 !important;

  color: var(--tl-text) !important;

  box-sizing: border-box !important;
}

body:has(input[placeholder*="Search job" i]) button {
  height: 32px !important;
  min-height: 32px !important;

  padding: 0 12px !important;

  border-radius: 10px !important;

  font-size: 10.5px !important;
  line-height: 1 !important;
  font-weight: 850 !important;

  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 6px !important;
}

/* Labels */
body:has(input[placeholder*="Search job" i]) label,
body:has(input[placeholder*="Search job" i]) [class*="label" i] {
  color: var(--tl-muted) !important;

  font-size: 10px !important;
  line-height: 1.1 !important;
  font-weight: 900 !important;
  letter-spacing: .04em !important;
  text-transform: uppercase !important;
}

/* Fix filter grid so it does not look too tall */
body:has(input[placeholder*="Search job" i]) :is(.filter-panel, .filters-panel, .task-filter-panel, .tasklist-filter-panel, [class*="filter" i]):has(input) {
  padding: 10px 12px !important;
  gap: 8px !important;
}

/* Record summary card */
body:has(input[placeholder*="Search job" i]) :is(section, article, div):has(:is(.badge, .pill, [class*="badge" i], [class*="pill" i])):has(button),
body:has(input[placeholder*="Search job" i]) :is(section, article, div):has(:is(.badge, .pill, [class*="badge" i], [class*="pill" i])):has(strong) {
  min-height: 52px !important;
  height: auto !important;

  padding: 10px 14px !important;

  border-radius: 14px !important;
  box-shadow: none !important;

  box-sizing: border-box !important;
}

/* Badges */
body:has(input[placeholder*="Search job" i]) :is(.badge, .pill, [class*="badge" i], [class*="pill" i]) {
  height: 28px !important;
  min-height: 28px !important;

  padding: 0 11px !important;

  border: 1px solid var(--tl-border) !important;
  border-radius: 999px !important;
  background: #ffffff !important;

  color: var(--tl-text) !important;

  font-size: 10.5px !important;
  font-weight: 850 !important;

  white-space: nowrap !important;
}

/* Summary text */
body:has(input[placeholder*="Search job" i]) :is(.summary-card, .record-summary, .task-summary, .tasklist-summary, [class*="summary" i], [class*="record" i]) :is(span, strong, p, small, div) {
  font-size: 10.5px !important;
  line-height: 1.2 !important;
  font-weight: 800 !important;
  color: var(--tl-muted) !important;
}

/* Schedule column fix */
body:has(input[placeholder*="Search job" i]) table th:nth-child(5),
body:has(input[placeholder*="Search job" i]) table td:nth-child(5) {
  min-width: 190px !important;
  width: 190px !important;
  max-width: 220px !important;

  white-space: normal !important;
  word-break: normal !important;
  overflow-wrap: break-word !important;

  text-align: left !important;
  vertical-align: middle !important;
}

body:has(input[placeholder*="Search job" i]) table td:nth-child(5) > div,
body:has(input[placeholder*="Search job" i]) table td:nth-child(5) > span {
  display: flex !important;
  flex-direction: column !important;
  align-items: flex-start !important;
  gap: 2px !important;
}

/* Table compact */
body:has(input[placeholder*="Search job" i]) table th,
body:has(input[placeholder*="Search job" i]) table td {
  font-size: 10.5px !important;
  line-height: 1.3 !important;
}

/* Avoid yellow highlight merging datetime */
body:has(input[placeholder*="Search job" i]) table td mark,
body:has(input[placeholder*="Search job" i]) table td .highlight {
  line-height: 1.25 !important;
}
