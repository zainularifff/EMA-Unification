/* TASK LIST SCHEDULE COLUMN FIX
   Safe CSS only. No runtime observer. No JSX change.
*/

/* Scope to task list pages/tables */
[class*="task" i] table th:nth-child(5),
[class*="task" i] table td:nth-child(5),
table:has(th:nth-child(5)):has(th:nth-child(6)) th:nth-child(5),
table:has(th:nth-child(5)):has(th:nth-child(6)) td:nth-child(5) {
  min-width: 190px !important;
  width: 190px !important;
  max-width: 220px !important;

  white-space: normal !important;
  word-break: normal !important;
  overflow-wrap: break-word !important;

  text-align: left !important;
  vertical-align: middle !important;
}

/* Schedule cell content should stack, not merge inline */
[class*="task" i] table td:nth-child(5) > div,
[class*="task" i] table td:nth-child(5) > span,
table:has(th:nth-child(5)):has(th:nth-child(6)) td:nth-child(5) > div,
table:has(th:nth-child(5)):has(th:nth-child(6)) td:nth-child(5) > span {
  display: flex !important;
  flex-direction: column !important;
  align-items: flex-start !important;
  gap: 2px !important;

  min-width: 0 !important;
  max-width: 100% !important;

  white-space: normal !important;
}

/* If search highlight wraps each datetime, force each mark/span onto new line */
[class*="task" i] table td:nth-child(5) mark,
table:has(th:nth-child(5)):has(th:nth-child(6)) td:nth-child(5) mark {
  display: inline-block !important;
  margin: 0 2px 2px 0 !important;
  padding: 0 2px !important;
  line-height: 1.25 !important;
}

[class*="task" i] table td:nth-child(5) mark + mark,
[class*="task" i] table td:nth-child(5) span + span,
table:has(th:nth-child(5)):has(th:nth-child(6)) td:nth-child(5) mark + mark,
table:has(th:nth-child(5)):has(th:nth-child(6)) td:nth-child(5) span + span {
  display: block !important;
  margin-top: 2px !important;
}

/* Schedule text style */
[class*="task" i] table td:nth-child(5),
[class*="task" i] table td:nth-child(5) *,
table:has(th:nth-child(5)):has(th:nth-child(6)) td:nth-child(5),
table:has(th:nth-child(5)):has(th:nth-child(6)) td:nth-child(5) * {
  font-size: 10.5px !important;
  line-height: 1.25 !important;
  font-weight: 750 !important;
  color: #0f2746 !important;

  writing-mode: horizontal-tb !important;
  text-orientation: mixed !important;
}

/* Header stays clean */
[class*="task" i] table th:nth-child(5),
table:has(th:nth-child(5)):has(th:nth-child(6)) th:nth-child(5) {
  white-space: nowrap !important;
  color: #2563eb !important;
  font-size: 10px !important;
  font-weight: 900 !important;
}

/* Do not let yellow highlight make datetime look like merged block */
[class*="task" i] table td:nth-child(5) .highlight,
table:has(th:nth-child(5)):has(th:nth-child(6)) td:nth-child(5) .highlight {
  display: inline-block !important;
  line-height: 1.25 !important;
}
