/* EMA TABLE SYSTEM LOCK FINAL
   Source of truth for ALL module tables.
   Locks: font family, font size, color, header, row height, cell vertical spacing, pagination.
*/

:root {
  --ema-table-font: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;

  --ema-table-bg: #ffffff;
  --ema-table-head-bg: #f4f7fb;
  --ema-table-border: #dbe7f6;
  --ema-table-row-border: #e7eef8;
  --ema-table-hover: #f8fbff;

  --ema-table-header-color: #2563eb;
  --ema-table-header-icon: #2563eb;
  --ema-table-text: #10294f;
  --ema-table-body: #18345f;
  --ema-table-muted: #64748b;
  --ema-table-blue: #2563eb;

  --ema-table-radius: 16px;

  --ema-table-head-height: 38px;
  --ema-table-row-height: 42px;

  --ema-table-header-font-size: 9.5px;
  --ema-table-body-font-size: 10.5px;
  --ema-table-main-font-size: 11.2px;
  --ema-table-sub-font-size: 9.2px;

  --ema-table-cell-x: 8px;
  --ema-table-cell-y: 4px;
}

/* =========================================================
   GLOBAL FONT LOCK INSIDE TABLES
========================================================= */
html body :is(
  .hardware-device-table,
  .software-device-table,
  .user-access-table,
  .advanced.clean-table,
  .settings-standard-table,
  .audit-standard-table,
  .service-desk-table,
  .ema-standard-table,
  .uam-table,
  .network-table,
  .network-standard-table,
  .app-table,
  .app-standard-table,
  .restriction-table,
  .patch-table,
  .task-table,
  .report-table,
  .inventory-table,
  .data-table,
  table
),
html body :is(
  .hardware-device-table,
  .software-device-table,
  .user-access-table,
  .advanced.clean-table,
  .settings-standard-table,
  .audit-standard-table,
  .service-desk-table,
  .ema-standard-table,
  .uam-table,
  .network-table,
  .network-standard-table,
  .app-table,
  .app-standard-table,
  .restriction-table,
  .patch-table,
  .task-table,
  .report-table,
  .inventory-table,
  .data-table,
  table
) * {
  font-family: var(--ema-table-font) !important;
  box-sizing: border-box !important;
}

/* =========================================================
   TABLE WRAPPER STANDARD
========================================================= */
html body :is(
  .hardware-device-table,
  .software-device-table,
  .user-access-table,
  .advanced.clean-table,
  .settings-standard-table,
  .audit-standard-table,
  .service-desk-table,
  .ema-standard-table,
  .uam-table,
  .network-table,
  .network-standard-table,
  .app-table,
  .app-standard-table,
  .restriction-table,
  .patch-table,
  .task-table,
  .report-table,
  .inventory-table,
  .data-table,
  table.ema-table,
  table.clean-table,
  table.standard-table
) {
  width: calc(100% - 2rem) !important;
  max-width: calc(100% - 2rem) !important;
  margin: 0 1rem 0.45rem !important;

  border: 1px solid var(--ema-table-border) !important;
  border-radius: var(--ema-table-radius) !important;
  background: var(--ema-table-bg) !important;
  box-shadow: none !important;

  overflow-x: hidden !important;
  overflow-y: visible !important;
  scrollbar-width: none !important;
  scrollbar-gutter: auto !important;
}

html body :is(
  .hardware-device-table,
  .software-device-table,
  .user-access-table,
  .advanced.clean-table,
  .settings-standard-table,
  .audit-standard-table,
  .service-desk-table,
  .ema-standard-table,
  .uam-table,
  .network-table,
  .app-table,
  .restriction-table,
  .patch-table,
  .task-table,
  .report-table,
  .inventory-table,
  .data-table
)::-webkit-scrollbar {
  width: 0 !important;
  height: 0 !important;
  display: none !important;
}

/* =========================================================
   HEADER ROW LOCK
========================================================= */
html body :is(
  .hardware-device-table-row.head,
  .software-device-table-row.head,
  .user-row.head,
  .clean-table-row.head,
  .settings-standard-row.head,
  .audit-standard-row.head,
  .service-desk-row.head,
  .ema-standard-row.head,
  .uam-table-row.head,
  [class*="table-row"].head,
  [class*="standard-row"].head
) {
  height: var(--ema-table-head-height) !important;
  min-height: var(--ema-table-head-height) !important;
  max-height: var(--ema-table-head-height) !important;

  background: var(--ema-table-head-bg) !important;
  border-bottom: 1px solid #d8e4f3 !important;

  position: sticky !important;
  top: 0 !important;
  z-index: 10 !important;

  overflow: hidden !important;
  scrollbar-width: none !important;
}

html body :is(
  .hardware-device-table-row.head,
  .software-device-table-row.head,
  .user-row.head,
  .clean-table-row.head,
  .settings-standard-row.head,
  .audit-standard-row.head,
  .service-desk-row.head,
  .ema-standard-row.head,
  .uam-table-row.head,
  [class*="table-row"].head,
  [class*="standard-row"].head
) > *,
html body :is(
  .hardware-device-table-row.head .user-cell,
  .software-device-table-row.head .user-cell,
  .user-row.head .user-cell,
  .clean-table-row.head .user-cell
),
html body table thead th {
  height: var(--ema-table-head-height) !important;
  min-height: var(--ema-table-head-height) !important;
  max-height: var(--ema-table-head-height) !important;

  display: flex !important;
  align-items: center !important;
  justify-content: flex-start !important;

  padding-top: 0 !important;
  padding-bottom: 0 !important;
  padding-left: var(--ema-table-cell-x) !important;
  padding-right: var(--ema-table-cell-x) !important;

  background: var(--ema-table-head-bg) !important;
  color: var(--ema-table-header-color) !important;

  font-family: var(--ema-table-font) !important;
  font-size: var(--ema-table-header-font-size) !important;
  line-height: 1 !important;
  font-weight: 900 !important;
  letter-spacing: 0.08em !important;
  text-transform: uppercase !important;

  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

/* kill blue / different sort header */
html body :is(
  .hardware-sort-btn,
  .software-sort-btn,
  .resource-sort-button,
  .table-sort-btn,
  .sort-btn,
  .sort-button,
  button[class*="sort"]
) {
  height: auto !important;
  min-height: 0 !important;

  padding: 0 !important;
  margin: 0 !important;

  display: inline-flex !important;
  align-items: center !important;
  gap: 3px !important;

  border: 0 !important;
  border-radius: 0 !important;
  background: transparent !important;
  box-shadow: none !important;

  color: var(--ema-table-header-color) !important;
  font-family: var(--ema-table-font) !important;
  font-size: var(--ema-table-header-font-size) !important;
  line-height: 1 !important;
  font-weight: 900 !important;
  letter-spacing: 0.08em !important;
  text-transform: uppercase !important;
  white-space: nowrap !important;
}

html body :is(
  .hardware-sort-btn,
  .software-sort-btn,
  .resource-sort-button,
  .table-sort-btn,
  .sort-btn,
  .sort-button,
  button[class*="sort"]
) svg,
html body :is(.software-sort-icon, .software-sort-icon.is-active) {
  color: var(--ema-table-header-icon) !important;
  stroke: var(--ema-table-header-icon) !important;
}

/* =========================================================
   BODY ROW LOCK
========================================================= */
html body :is(
  .hardware-device-table-row:not(.head),
  .software-device-table-row:not(.head),
  .user-row:not(.head),
  .clean-table-row:not(.head),
  .settings-standard-row:not(.head),
  .audit-standard-row:not(.head),
  .service-desk-row:not(.head),
  .ema-standard-row:not(.head),
  .uam-table-row:not(.head),
  [class*="table-row"]:not(.head),
  [class*="standard-row"]:not(.head)
) {
  height: var(--ema-table-row-height) !important;
  min-height: var(--ema-table-row-height) !important;
  max-height: var(--ema-table-row-height) !important;

  background: var(--ema-table-bg) !important;
  border-bottom: 1px solid var(--ema-table-row-border) !important;

  overflow: hidden !important;
}

html body :is(
  .hardware-device-table-row:not(.head),
  .software-device-table-row:not(.head),
  .user-row:not(.head),
  .clean-table-row:not(.head),
  .settings-standard-row:not(.head),
  .audit-standard-row:not(.head),
  .service-desk-row:not(.head),
  .ema-standard-row:not(.head),
  .uam-table-row:not(.head),
  [class*="table-row"]:not(.head),
  [class*="standard-row"]:not(.head)
):hover {
  background: var(--ema-table-hover) !important;
}

/* =========================================================
   BODY CELL LOCK - SAME FONT/SIZE/COLOR/SPACING
========================================================= */
html body :is(
  .hardware-device-table-row,
  .software-device-table-row,
  .user-row,
  .clean-table-row,
  .settings-standard-row,
  .audit-standard-row,
  .service-desk-row,
  .ema-standard-row,
  .uam-table-row,
  [class*="table-row"],
  [class*="standard-row"]
) > *,
html body :is(
  .hardware-device-table-row .user-cell,
  .software-device-table-row .user-cell,
  .user-row .user-cell,
  .clean-table-row .user-cell
),
html body table tbody td {
  min-width: 0 !important;

  height: var(--ema-table-row-height) !important;
  min-height: var(--ema-table-row-height) !important;
  max-height: var(--ema-table-row-height) !important;

  display: flex !important;
  flex-direction: column !important;
  justify-content: center !important;

  padding-top: var(--ema-table-cell-y) !important;
  padding-bottom: var(--ema-table-cell-y) !important;
  padding-left: var(--ema-table-cell-x) !important;
  padding-right: var(--ema-table-cell-x) !important;

  color: var(--ema-table-body) !important;
  font-family: var(--ema-table-font) !important;
  font-size: var(--ema-table-body-font-size) !important;
  line-height: 1.15 !important;
  font-weight: 750 !important;

  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  scrollbar-width: none !important;
}

html body :is(
  .hardware-device-table-row,
  .software-device-table-row,
  .user-row,
  .clean-table-row,
  .settings-standard-row,
  .audit-standard-row,
  .service-desk-row,
  .ema-standard-row,
  .uam-table-row,
  [class*="table-row"],
  [class*="standard-row"]
) > *::-webkit-scrollbar {
  width: 0 !important;
  height: 0 !important;
  display: none !important;
}

/* main value */
html body :is(
  .hardware-device-table-row,
  .software-device-table-row,
  .user-row,
  .clean-table-row,
  .settings-standard-row,
  .audit-standard-row,
  .service-desk-row,
  .ema-standard-row,
  .uam-table-row,
  [class*="table-row"],
  [class*="standard-row"]
) strong,
html body table tbody td strong {
  display: block !important;
  max-width: 100% !important;

  color: var(--ema-table-text) !important;
  font-family: var(--ema-table-font) !important;
  font-size: var(--ema-table-main-font-size) !important;
  line-height: 1.1 !important;
  font-weight: 900 !important;

  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

/* sub value */
html body :is(
  .hardware-device-table-row,
  .software-device-table-row,
  .user-row,
  .clean-table-row,
  .settings-standard-row,
  .audit-standard-row,
  .service-desk-row,
  .ema-standard-row,
  .uam-table-row,
  [class*="table-row"],
  [class*="standard-row"]
) small,
html body table tbody td small {
  display: block !important;
  max-width: 100% !important;

  margin-top: 2px !important;

  color: var(--ema-table-muted) !important;
  font-family: var(--ema-table-font) !important;
  font-size: var(--ema-table-sub-font-size) !important;
  line-height: 1.05 !important;
  font-weight: 750 !important;

  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

/* =========================================================
   NO COLUMN / NUMBERING LOCK
========================================================= */
html body :is(
  .hardware-device-table-row,
  .software-device-table-row,
  .user-row,
  .clean-table-row,
  .settings-standard-row,
  .audit-standard-row,
  .service-desk-row,
  .ema-standard-row,
  .uam-table-row,
  [class*="table-row"],
  [class*="standard-row"]
) > *:first-child,
html body table th:first-child,
html body table td:first-child {
  align-items: center !important;
  justify-content: center !important;
  text-align: center !important;

  color: var(--ema-table-muted) !important;
  font-size: 10px !important;
  font-weight: 900 !important;
}

html body :is(
  .row-index-pill,
  .software-row-no,
  .hardware-row-no,
  .uam-row-index,
  .settings-row-index,
  .audit-row-index,
  .table-row-index,
  .ema-row-index,
  .ema-row-number,
  .row-number-pill,
  .row-number,
  .index-pill,
  .no-pill
) {
  width: auto !important;
  height: auto !important;
  min-width: 0 !important;
  min-height: 0 !important;
  max-width: none !important;
  max-height: none !important;

  display: inline-block !important;
  padding: 0 !important;
  margin: 0 !important;

  border: 0 !important;
  border-radius: 0 !important;
  background: transparent !important;
  box-shadow: none !important;
  outline: none !important;

  color: var(--ema-table-muted) !important;
  font-family: var(--ema-table-font) !important;
  font-size: 10px !important;
  line-height: 1 !important;
  font-weight: 900 !important;
}

html body :is(
  .row-index-pill,
  .software-row-no,
  .hardware-row-no,
  .uam-row-index,
  .settings-row-index,
  .audit-row-index,
  .table-row-index,
  .ema-row-index,
  .ema-row-number,
  .row-number-pill,
  .row-number,
  .index-pill,
  .no-pill
)::before,
html body :is(
  .row-index-pill,
  .software-row-no,
  .hardware-row-no,
  .uam-row-index,
  .settings-row-index,
  .audit-row-index,
  .table-row-index,
  .ema-row-index,
  .ema-row-number,
  .row-number-pill,
  .row-number,
  .index-pill,
  .no-pill
)::after {
  content: none !important;
  display: none !important;
}

/* =========================================================
   PILL / DATE / STATUS LOCK
========================================================= */
html body :is(
  .hardware-device-table-row,
  .software-device-table-row,
  .user-row,
  .clean-table-row,
  .settings-standard-row,
  .audit-standard-row,
  .service-desk-row,
  .ema-standard-row,
  .uam-table-row,
  [class*="table-row"],
  [class*="standard-row"]
) span[class*="pill"],
html body :is(
  .software-date-cell,
  .hardware-date-pill,
  .status-pill,
  .ema-status-pill,
  .badge
) {
  width: fit-content !important;
  max-width: 100% !important;

  height: 22px !important;
  min-height: 22px !important;

  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;

  padding: 0 9px !important;

  border-radius: 999px !important;

  font-family: var(--ema-table-font) !important;
  font-size: 9.5px !important;
  line-height: 1 !important;
  font-weight: 900 !important;

  white-space: nowrap !important;
}

html body :is(.software-date-cell, .hardware-date-pill, .muted-cell.software-date-cell) {
  border: 1px solid #cbd5e1 !important;
  background: #f8fafc !important;
  color: var(--ema-table-text) !important;
}

/* =========================================================
   PAGINATION LOCK - SAME FOR ALL TABLES
========================================================= */
html body :is(
  .uam-pagination,
  .global-style.uam-pagination,
  .software-page-pagination,
  .hardware-stat-pagination,
  .ema-pagination,
  .pagination-row
) {
  width: calc(100% - 2rem) !important;
  max-width: calc(100% - 2rem) !important;

  height: 32px !important;
  min-height: 32px !important;

  margin: 8px 1rem 0 !important;
  padding: 0 2px !important;

  display: grid !important;
  grid-template-columns: auto 1fr auto !important;
  align-items: center !important;

  border: 0 !important;
  border-radius: 0 !important;
  background: transparent !important;
  box-shadow: none !important;
  overflow: visible !important;
}

html body :is(.uam-page-summary, .pagination-summary) {
  height: 30px !important;
  min-height: 30px !important;

  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;

  padding: 0 12px !important;
  border-radius: 999px !important;

  border: 1px solid #d8e4f3 !important;
  background: #ffffff !important;
  color: var(--ema-table-text) !important;

  font-family: var(--ema-table-font) !important;
  font-size: 10.5px !important;
  line-height: 30px !important;
  font-weight: 850 !important;

  white-space: nowrap !important;
}

html body :is(.uam-pagination-controls, .pagination-controls) {
  height: 34px !important;
  min-height: 34px !important;

  display: inline-flex !important;
  align-items: center !important;
  justify-content: flex-end !important;
  gap: 6px !important;

  padding: 0 !important;
  margin: 0 !important;

  border: 0 !important;
  border-radius: 0 !important;
  background: transparent !important;
  box-shadow: none !important;
}

html body :is(.uam-page-icon, .uam-page-current, .pagination-button, .pagination-current) {
  width: 30px !important;
  min-width: 30px !important;
  max-width: 30px !important;

  height: 30px !important;
  min-height: 30px !important;
  max-height: 30px !important;

  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;

  padding: 0 !important;
  margin: 0 !important;

  border-radius: 10px !important;

  font-family: var(--ema-table-font) !important;
  font-size: 11px !important;
  line-height: 1 !important;
  font-weight: 900 !important;
}

html body :is(.uam-page-icon, .pagination-button) {
  border: 1px solid #d8e4f3 !important;
  background: #ffffff !important;
  color: #1d4ed8 !important;
}

html body :is(.uam-page-current, .pagination-current) {
  border: 1px solid var(--ema-table-blue) !important;
  background: var(--ema-table-blue) !important;
  color: #ffffff !important;
  box-shadow: 0 9px 20px rgba(37, 99, 235, 0.26) !important;
}

/* =========================================================
   HARDWARE/SOFTWARE DOT ALIGNMENT
========================================================= */
html body .software-user-name {
  width: 100% !important;
  min-width: 0 !important;

  display: grid !important;
  grid-template-columns: 12px minmax(0, 1fr) !important;
  align-items: center !important;
  column-gap: 8px !important;
}

html body .software-user-name > div {
  min-width: 0 !important;
  overflow: hidden !important;
}

html body :is(.software-status-dot, .hardware-status-dot, .device-status-dot) {
  position: static !important;
  left: auto !important;
  top: auto !important;
  transform: none !important;

  width: 9px !important;
  height: 9px !important;
  min-width: 9px !important;

  display: inline-block !important;

  margin: 0 !important;
  border-radius: 999px !important;
  background: var(--ema-table-muted) !important;
  box-shadow: 0 0 0 4px #e2e8f0 !important;
}

/* =========================================================
   CARD / WRAPPER LOCK
========================================================= */
html body :is(.hardware-registry-card, .software-registry-card, .content-shell, .ema-panel-surface) {
  overflow: hidden !important;
}

/* responsive: horizontal scroll only when really small */
@media (max-width: 1280px) {
  html body :is(
    .hardware-device-table,
    .software-device-table,
    .user-access-table,
    .advanced.clean-table,
    .settings-standard-table,
    .audit-standard-table,
    .service-desk-table,
    .ema-standard-table,
    .uam-table,
    .network-table,
    .app-table,
    .restriction-table,
    .patch-table,
    .task-table,
    .report-table,
    .inventory-table,
    .data-table
  ) {
    overflow-x: auto !important;
    overflow-y: visible !important;
    scrollbar-width: thin !important;
  }
}


/* EMA NUMBERING COLUMN LOCK FINAL START */
/* Force one numbering format for ALL module tables */

:root {
  --ema-table-no-width: 52px;
  --ema-table-no-color: #64748b;
  --ema-table-no-font-size: 10px;
  --ema-table-no-font-weight: 900;
}

/* Force first column width + alignment for div/grid tables */
html body :is(
  .hardware-device-table-row,
  .software-device-table-row,
  .user-row,
  .clean-table-row,
  .settings-standard-row,
  .audit-standard-row,
  .service-desk-row,
  .ema-standard-row,
  .uam-table-row,
  [class*="table-row"],
  [class*="standard-row"]
) > :first-child {
  width: var(--ema-table-no-width) !important;
  min-width: var(--ema-table-no-width) !important;
  max-width: var(--ema-table-no-width) !important;

  padding-left: 0 !important;
  padding-right: 0 !important;
  padding-top: 0 !important;
  padding-bottom: 0 !important;

  display: flex !important;
  flex-direction: row !important;
  align-items: center !important;
  justify-content: center !important;

  text-align: center !important;
